# ─────────────────────────────────────────────
# Configuración del Scraper - ai-client-scrapper
# ─────────────────────────────────────────────

# Palabra clave de búsqueda (se puede sobreescribir en tiempo de ejecución)
SEARCH_KEYWORD=instalaciones solares

# Número máximo de páginas a paginar por fuente
MAX_PAGES=5

# Ruta de la base de datos SQLite
DATABASE_URL=sqlite:///data/leads.db

# Directorio de logs
LOG_DIR=logs

# Modo headless del navegador (true/false)
HEADLESS=true

# ─────────────────────────────────────────────
# Configuración SMTP para envío de emails
# ─────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-password-de-aplicacion

# Modo de prueba (Dry Run) - No envía emails reales
DRY_RUN=true
